# ============================================================
# Quoting Pipeline Environment
# Kopiere diese Datei nach ".env" und trage echte Keys ein.
# ".env" sollte NICHT committed werden.
# ============================================================

# Base URL der API. Default: http://127.0.0.1:8000
#API_BASE_URL=
STREAMLIT_BASE_URL=http://localhost:8501

# Provider: "gemini" oder "azure"
LLM_PROVIDER=gemini

# ----------------------------
# Gemini
# ----------------------------
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
# 0 = thinking off (default, ~30 % faster TTFT for structured extraction).
# -1 = use SDK default (dynamic thinking).
GEMINI_THINKING_BUDGET=0

# ----------------------------
# Azure OpenAI / Nexus
# ----------------------------
NEXUS_API_KEY=
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_MODEL=gpt-5-mini


# ----------------------------
# Runtime
# ----------------------------
LLM_MAX_RETRIES=3
LLM_TIMEOUT_S=120

# ----------------------------
# Paths
# Windows-Beispiel:
# OUTPUT_DIR=C:\Business & AI\Output
#
# Relatives Beispiel:
# OUTPUT_DIR=./output
# DATA_DIR=./data
# ----------------------------
OUTPUT_DIR=./output
DATA_DIR=./data

# ----------------------------
# Matching
# ----------------------------
FUZZY_THRESHOLD=85
SEMANTIC_THRESHOLD=70

# ----------------------------
# PDF Rendering
# ----------------------------
PDF_RENDER_DPI=200