# ============================================================
# Quoting Pipeline Environment
# Kopiere diese Datei nach ".env" und trage echte Keys ein.
# ".env" sollte NICHT committed werden.
# ============================================================

# Provider: "gemini" oder "azure"
LLM_PROVIDER=gemini

# ----------------------------
# Gemini
# ----------------------------
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# ----------------------------
# Azure OpenAI / Nexus
# ----------------------------
NEXUS_API_KEY=
AZURE_OPENAI_ENDPOINT=https://genai-nexus.api.corpinter.net/
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_MODEL=gpt-5-mini

# ----------------------------
# Runtime
# ----------------------------
LLM_MAX_RETRIES=3
LLM_TIMEOUT_S=120

# ----------------------------
# Paths
# Windows-Beispiel:
# OUTPUT_DIR=C:\Business & AI\Output
#
# Relatives Beispiel:
# OUTPUT_DIR=./output
# DATA_DIR=./data
# ----------------------------
OUTPUT_DIR=C:\Business & AI\Output
DATA_DIR=./data

# ----------------------------
# Matching
# ----------------------------
FUZZY_THRESHOLD=85
SEMANTIC_THRESHOLD=70

# ----------------------------
# PDF Rendering
# ----------------------------
PDF_RENDER_DPI=200